{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "customTemplates": [
    {
      "name": "front-page",
      "title": "Forside",
      "postTypes": ["page"]
    }
  ],
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ],
  "settings": {
    "color": {
      "palette": [
        {
          "name": "Primary",
          "slug": "primary",
          "color": "#09afb3"
        },
        {
          "name": "Dark",
          "slug": "dark",
          "color": "#0d0d0d"
        },
        {
          "name": "Light",
          "slug": "light",
          "color": "#ffffff"
        },
        {
          "name": "Gradient Start",
          "slug": "gradient-start",
          "color": "#ff7500"
        },
        {
          "name": "Gradient End",
          "slug": "gradient-end",
          "color": "#f4be31"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "name": "Staatliches",
          "slug": "heading",
          "fontFamily": "Staatliches, sans-serif"
        },
        {
          "name": "DM Sans",
          "slug": "body",
          "fontFamily": "DM Sans, sans-serif"
        }
      ]
    },
    "spacing": {
      "spacingScale": {
        "steps": 7
      }
    }
  },
  "styles": {
    "color": {
      "background": "#0d0d0d",
      "text": "#ffffff"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "fontSize": "1rem",
      "lineHeight": "1.6"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)"
        }
      },
      "button": {
        "color": {
          "background": "#09afb3",
          "text": "#ffffff"
        }
      }
    }
  }
}