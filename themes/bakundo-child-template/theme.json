{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "color": {
      "palette": [
        {
          "name": "Primary",
          "slug": "primary",
          "color": "#000000"
        },
        {
          "name": "Dark",
          "slug": "dark",
          "color": "#0d0d0d"
        },
        {
          "name": "Light",
          "slug": "light",
          "color": "#ffffff"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "name": "Heading Font",
          "slug": "heading",
          "fontFamily": "Sans-serif"
        },
        {
          "name": "Body Font",
          "slug": "body",
          "fontFamily": "Sans-serif"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "#ffffff",
      "text": "#0d0d0d"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "fontSize": "1rem",
      "lineHeight": "1.6"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)"
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "#ffffff"
        }
      }
    }
  }
}
